<?xml version="1.0" encoding="utf-8"?>
<robot name="quadruped_broken_cad">
  <!-- Base Link (Nominal) -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.15" ixy="0.0" ixz="0.0" iyy="0.25" iyz="0.0" izz="0.30"/>
    </inertial>
  </link>

  <!-- Hip Yaw Link (CAD Error 1: Negative/Zero Mass) -->
  <link name="hip_yaw_link">
    <inertial>
      <origin xyz="0.01 0.02 -0.01" rpy="0 0 0"/>
      <mass value="-0.85"/> <!-- NEGATIVE MASS -->
      <inertia ixx="0.0012" ixy="0.0" ixz="0.0" iyy="0.0015" iyz="0.0" izz="0.0018"/>
    </inertial>
  </link>

  <!-- Upper Leg Link (CAD Error 2: Triangle Inequality Breach) -->
  <link name="upper_leg_link">
    <inertial>
      <origin xyz="0.0 0.0 -0.12" rpy="0 0 0"/>
      <mass value="1.25"/>
      <!-- ixx + iyy must be >= izz. Here, 0.002 + 0.002 = 0.004, which is far less than izz (0.050). -->
      <!-- Represents an impossible needle/flat distribution that will explode physics engines. -->
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.050"/>
    </inertial>
  </link>

  <!-- Lower Leg Link (CAD Error 3: Non-Positive-Definite Inertia Matrix) -->
  <link name="lower_leg_link">
    <inertial>
      <origin xyz="0.0 0.0 -0.15" rpy="0 0 0"/>
      <mass value="0.45"/>
      <!-- Constructing a tensor that is not positive-definite due to dominant off-diagonal elements. -->
      <!-- Det(I_2D) = ixx*iyy - ixy^2 = 0.0005*0.0005 - 0.0015^2 = 2.5e-7 - 2.25e-6 < 0 -->
      <inertia ixx="0.0005" ixy="0.0015" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0008"/>
    </inertial>
  </link>
</robot>
